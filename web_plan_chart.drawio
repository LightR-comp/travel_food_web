        <mxCell id="AmzwU83vJtOXyPDXre5B-26" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="AmzwU83vJtOXyPDXre5B-22" target="AmzwU83vJtOXyPDXre5B-25" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <UserObject label="AI Chatbot" tooltip="KIẾN TRÚC CHATBOT: RAG (RETRIEVAL-AUGMENTED GENERATION)&#xa;&#xa;+ TRUY VẤN (RETRIEVAL): TÌM KIẾM NGỮ NGHĨA TRONG VECTOR DATABASE (CHROMA DB/PINECONE) ĐỂ LẤY DỮ LIỆU MÓN ĂN CHÍNH XÁC.&#xa;&#xa;+ TĂNG CƯỜNG (AUGMENTATION): GỘP YÊU CẦU CỦA USER VỚI DỮ LIỆU THỰC TẾ TỪ CSDL VÀO PROMPT NGỮ CẢNH.&#xa;&#xa;+ TẠO CÂU TRẢ LỜI (GENERATION): AI SOẠN THẢO CÂU TRẢ LỜI DỰA TRÊN 100% THÔNG TIN NỘI BỘ, LOẠI BỎ HOÀN TOÀN ẢO GIÁC." id="AmzwU83vJtOXyPDXre5B-22">
          <mxCell style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFB570;strokeColor=#d79b00;" parent="1" vertex="1">
            <mxGeometry x="450" y="30" width="120" height="40" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="AmzwU83vJtOXyPDXre5B-29" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="AmzwU83vJtOXyPDXre5B-23" target="AmzwU83vJtOXyPDXre5B-28" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <UserObject label="System Assistant" tooltip="## CỔNG TIẾP NHẬN &amp; PHÂN TÍCH Ý ĐỊNH (NLP GATEWAY):&#xa;&#xa;+ PHÂN TÍCH Ý ĐỊNH (INTENT CLASSIFICATION):&#xa;&#xa;VAI TRÒ: ĐÂY LÀ &quot;CỬA NGÕ&quot; TIẾP NHẬN YÊU CẦU TỪ NGƯỜI DÙNG. HỆ THỐNG KHÔNG CHỈ TRÍCH XUẤT TỪ KHÓA MÀ PHẢI HIỂU ĐƯỢC MỤC ĐÍCH CUỐI CÙNG (USER INTENT).&#xa;&#xa;+ CÁC LOẠI Ý ĐỊNH PHỔ BIẾN:&#xa;&#xa;TÌM KIẾM ĐỊA ĐIỂM: &quot;TÌM QUÁN LẨU GẦN ĐÂY.&quot;&#xa;&#xa;GỢI Ý THEO TÂM TRẠNG: &quot;ĐANG THẤT TÌNH, MUỐN ĂN GÌ ĐÓ NGỌT.&quot;&#xa;&#xa;LỌC THEO ĐIỀU KIỆN NHÓM: &quot;NHÓM 10 NGƯỜI ĐI ĂN TỐI, CÓ CHỖ ĐẬU XE.&quot;&#xa;&#xa;+ TRÍCH XUẤT THỰC THỂ (ENTITY EXTRACTION)&#xa;CƠ CHẾ:&#xa;&#xa;SỬ DỤNG PROMPT ENGINEERING ĐỂ ÉP MÔ HÌNH AI (VÍ DỤ: GEMINI, GPT) TRẢ VỀ CẤU TRÚC JSON CHUẨN TỪ CÂU CHAT CỦA NGƯỜI DÙNG.&#xa;&#xa;CÁC THỰC THỂ CẦN BÓC TÁCH:&#xa;&#xa;FOOD_ITEM: PHỞ, BÚN CHẢ, PIZZA...&#xa;&#xa;NUMBER_OF_PEOPLE: 2 NGƯỜI, NHÓM ĐÔNG, 15 KHÁCH...&#xa;&#xa;BUDGET: RẺ, SANG TRỌNG, DƯỚI 500K...&#xa;&#xa;LOCATION_RELEVANCE: GẦN ĐÂY, QUẬN 1, BÁN KÍNH 2KM...&#xa;&#xa;RESTRICTIONS: DỊ ỨNG HẢI SẢN, KHÔNG ĂN CAY, ĂN CHAY...&#xa;&#xa;+ QUY TRÌNH VẬN HÀNH (WORKFLOW):&#xa;&#xa;BƯỚC 1: NHẬN CÂU TRUY VẤN (RAW TEXT) TỪ CLIENT.&#xa;&#xa;BƯỚC 2: AI XỬ LÝ VÀ CHUYỂN ĐỔI THÀNH DỮ LIỆU ĐỊNH DẠNG (STRUCTURED DATA).&#xa;&#xa;BƯỚC 3: TRUYỀN CẤU TRÚC JSON NÀY VÀO BỘ LỌC (FILTER) VÀ CÔNG THỨC CHẤM ĐIỂM (SCORING) ĐÃ THIẾT LẬP Ở CÁC BƯỚC TRƯỚC." id="AmzwU83vJtOXyPDXre5B-23">
          <mxCell style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
            <mxGeometry x="280" y="170" width="120" height="40" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="Consultant" tooltip="## VAI TRÒ TƯ VẤN (CONSULTANT ROLE):&#xa;&#xa;+ ĐÓNG VAI &quot;THỔ ĐỊA&quot; SỐ: AI KHÔNG CHỈ TRẢ LỜI KHÔ KHAN MÀ CÒN SỬ DỤNG NGÔN NGỮ ĐỊA PHƯƠNG, AM HIỂU VỀ VĂN HÓA ẨM THỰC ĐỂ TƯ VẤN CHO KHÁCH DU LỊCH.&#xa;&#xa;+ KẾT HỢP VỚI KHẢ NĂNG CÓ SẴN VỀ PHÂN TÍCH MÓN ĂN CŨNG NHƯ NĂNG LỰC VẤN ĐÁP CỦA AI &#xa;&#xa;+ CÁCH VẬN HÀNH: DANH SÁCH QUÁN ĂN TỪ BỘ LỌC ĐƯỢC ĐƯA VÀO PROMPT ĐỂ AI &quot;VIẾT LẠI&quot; THÀNH MỘT BẢN TIN TƯ VẤN HẤP DẪN, GỢI CẢM XÚC VÀ CÓ " id="AmzwU83vJtOXyPDXre5B-25">
          <mxCell style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
            <mxGeometry x="735" y="30" width="120" height="40" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="AmzwU83vJtOXyPDXre5B-27" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="AmzwU83vJtOXyPDXre5B-8" target="AmzwU83vJtOXyPDXre5B-23" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="AmzwU83vJtOXyPDXre5B-36" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="AmzwU83vJtOXyPDXre5B-28" target="AmzwU83vJtOXyPDXre5B-31" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="AmzwU83vJtOXyPDXre5B-37" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="AmzwU83vJtOXyPDXre5B-28" target="AmzwU83vJtOXyPDXre5B-40" edge="1">
